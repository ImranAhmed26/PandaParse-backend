PORT=8000
# Local PostgreSQL Connection
DATABASE_URL=your-database-url
PRISMA_MIGRATE_SKIP_SHADOW_DATABASE_CHECK=1

# Textract-specific (used by Lambda)
AWS_REGION=
TEXTRACT_ROLE_ARN=
TEXTRACT_SNS_TOPIC_ARN=
TEXTRACT_OUTPUT_BUCKET=

# Pre-signed S3 upload (NestJS backend use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# SQS Configuration for upload processing
SQS_QUEUE_URL=

# JWT
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend (used as the ID-token audience).
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Internal API Key for AWS operations
INTERNAL_API_KEY=your-internal-api-key-here

# CORS Configuration
FRONTEND_URL=your-frontend-url